# Backend Environment - Production
# Copy to application-prod.yml or set as environment variables

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/unza_hospital
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=11111111

# JWT
UNZA_JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_SECRET_MIN_256_BITS

# Flyway
SPRING_FLYWAY_ENABLED=true

# Actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,loggers,prometheus

# Counseling System Integration
# Base URL of the counseling system backend (leave blank for offline/graceful-fallback mode)
COUNSELING_SYSTEM_URL=http://counseling-host:8080
# Long-lived service-account token from counseling system (ROLE_COUNSELOR)
# Generate via: POST /api/auth/login with counseling service account, then store that token here
COUNSELING_SERVICE_TOKEN=

# UNZA HR System Integration (staff & dependents metadata)
# Base URL of the HR system (leave blank for offline/graceful-fallback mode)
HR_SYSTEM_URL=http://devhr.unza.zm
# Service-account credentials issued by HR for the clinic system
HR_SERVICE_USERNAME=
HR_SERVICE_PASSWORD=
# Optional: static override token (skips auto-login when set)
HR_SERVICE_TOKEN=
